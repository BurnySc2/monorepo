{
    "name": "bored_gems",
    "version": "0.0.1",
    "scripts": {
        "dev": "cross-env DEV=true vite dev --port 3000",
        "build": "vite build",
        "build-precommit": "vite build | grep ERR",
        "preview": "vite preview",
        "test": "playwright test",
        "test:all": "playwright test --browser=all --workers=1",
        "test:debug": "PWDEBUG=1 playwright test",
        "check": "svelte-check --tsconfig tsconfig.json",
        "check:watch": "svelte-check --tsconfig tsconfig.json --watch",
        "lint": "eslint --ignore-path .gitignore .  --max-warnings 0",
        "lint:fix": "eslint --fix --ignore-path .gitignore .  --max-warnings 0",
        "format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. .",
        "prune": "rm node_modules -rf && rm package-lock.json -f && npm i",
        "update": "npx npm-check-updates -u && npm run prune"
    },
    "devDependencies": {
        "@playwright/test": "^1.23.4",
        "@supabase/supabase-js": "^1.35.4",
        "@sveltejs/adapter-auto": "1.0.0-next.61",
        "@sveltejs/kit": "1.0.0-next.377",
        "@trivago/prettier-plugin-sort-imports": "^3.2.0",
        "@typescript-eslint/eslint-plugin": "^5.30.6",
        "@typescript-eslint/parser": "^5.30.6",
        "cross-env": "^7.0.3",
        "eslint": "^8.20.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-svelte3": "^4.0.0",
        "prettier": "^2.7.1",
        "prettier-plugin-svelte": "^2.7.0",
        "supabase": "^1.27.7",
        "svelte": "^3.49.0",
        "svelte-check": "^2.8.0",
        "svelte-preprocess": "^4.10.7",
        "typescript": "~4.7.4"
    },
    "type": "module"
}
